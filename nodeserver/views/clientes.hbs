<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Lista de Clientes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
    <h1 class="text-success mb-4">👤 Listado Oficial de Clientes</h1>
    
    <ul class="list-group shadow-sm">
        {{#each clientes}}
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <strong>{{this.nombre}}</strong>
            <span class="badge bg-success rounded-pill">{{this.email}}</span>
        </li>
        {{else}}
        <li class="list-group-item list-group-item-warning">No hay clientes registrados en la base de datos.</li>
        {{/each}}
    </ul>

    <div class="mt-4 d-flex gap-2">
        <a href="/" class="btn btn-outline-secondary">🏠 Volver al Inicio</a>
        <a href="/finanzas" class="btn btn-success">← Volver a Finanzas</a>
    </div>
</body>
</html>