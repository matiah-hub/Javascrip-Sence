<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Finanzas Personales</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
    <h1 class="text-primary mb-4">📊 Estado de Finanzas Personales</h1>
    
    <table class="table table-hover table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Nombre / Concepto</th>
                <th>Me Debe</th>
                <th>Le Debo</th>
                <th>Cuotas Pagar</th>
            </tr>
        </thead>
        <tbody>
            {{#each finanzas}}
            <tr>
                <td>{{this.nombre}}</td>
                <td class="text-success">${{this.me_debe}}</td>
                <td class="text-danger">${{this.le_debo}}</td>
                <td>{{this.cuotas_pagar}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div class="mt-4 d-flex gap-2">
        <a href="/" class="btn btn-outline-secondary">🏠 Volver al Inicio</a>
        <a href="/clientes" class="btn btn-primary">Ir a Clientes →</a>
    </div>
</body>
</html>